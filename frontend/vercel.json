{
  "routes": [
    {
      "src": "^/avatar-loop\\.mp4$",
      "dest": "/avatar-loop.mp4"
    },
    {
      "src": "^/(favicon\\.ico|illustration\\.png|avatar-loop\\.mp4)$",
      "dest": "/$1"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.*\\.(png|jpg|jpeg|webp|svg|ico|gif))$",
      "dest": "/$1"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}
